# Copy these into Vercel: Project → Settings → Environment Variables
# All three are required for the contact form to work.

# From https://resend.com/api-keys
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXX

# Sender address shown on emails.
# Use onboarding@resend.dev until raktechnologies.co.za is verified in Resend.
# After domain verification change to: RAK Technologies <info@raktechnologies.co.za>
RESEND_FROM=RAK Technologies <onboarding@resend.dev>

# Where form submissions are delivered
CONTACT_EMAIL=info@raktechnologies.co.za
